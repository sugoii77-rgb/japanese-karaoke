# Google Cloud Translation API 키 (선택 사항)
# 설정하면 Jisho 영어 뜻을 자동으로 한국어로 번역합니다.
# 설정하지 않으면 수동 wordMap/englishMap만 사용합니다.
#
# 발급 방법:
#   1. https://console.cloud.google.com 접속
#   2. Cloud Translation API 활성화
#   3. API 키 생성 후 아래에 입력
#
GOOGLE_TRANSLATE_API_KEY=your_api_key_here

# Vercel 배포 시에는 Vercel 대시보드 > Settings > Environment Variables에 추가
